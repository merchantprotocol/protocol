#!/bin/bash
# ============================================================================
# Protocol — One-Line Installer
# ============================================================================
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/merchantprotocol/protocol/master/bin/install | bash
#
# Install nightly (latest from master, may be unstable):
#   curl -fsSL https://raw.githubusercontent.com/merchantprotocol/protocol/master/bin/install | bash -s -- --nightly
#
# Options:
#   --nightly   Install from the latest master branch instead of the latest release tag.
#               Use this if you want bleeding-edge features (may be unstable).
#
# Idempotent — safe to run multiple times.
# Supports macOS (Homebrew) and Linux (Amazon Linux, Ubuntu).
# ============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
REPO_URL="https://github.com/merchantprotocol/protocol.git"
REPO_OWNER="merchantprotocol"
REPO_NAME="protocol"
BINARY_NAME="protocol"
INSTALL_DIR="$HOME/.protocol"
MIN_PHP_VERSION="8.4"
USE_NIGHTLY=false

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
for arg in "$@"; do
  case "$arg" in
    --nightly) USE_NIGHTLY=true ;;
  esac
done

# ---------------------------------------------------------------------------
# Terminal UI — Colors & Symbols
# ---------------------------------------------------------------------------
BOLD="\033[1m"
DIM="\033[2m"
RESET="\033[0m"
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
WHITE="\033[1;37m"

CHECK="${GREEN}✔${RESET}"
CROSS="${RED}✖${RESET}"
WARN_SYM="${YELLOW}⚠${RESET}"
ARROW="${BLUE}›${RESET}"

# Spinner frames
SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
SPINNER_PID=""

# Log file for suppressed output
INSTALL_LOG="/tmp/protocol-install.log"
: > "$INSTALL_LOG"

# ---------------------------------------------------------------------------
# Terminal UI — Primitives
# ---------------------------------------------------------------------------
hide_cursor() { printf "\033[?25l"; }
show_cursor() { printf "\033[?25h"; }

cleanup() {
  stop_spinner 2>/dev/null
  show_cursor
  if [ "${INSTALL_FAILED:-false}" = true ]; then
    echo ""
    printf "  ${DIM}Full log: %s${RESET}\n" "$INSTALL_LOG"
  fi
}
trap cleanup EXIT

clear_line() { printf "\r\033[2K"; }

start_spinner() {
  local msg="$1"
  stop_spinner 2>/dev/null
  (
    local i=0
    while true; do
      local frame="${SPINNER_FRAMES[$((i % ${#SPINNER_FRAMES[@]}))]}"
      printf "\r  ${CYAN}%s${RESET} %s" "$frame" "$msg"
      sleep 0.08
      i=$((i + 1))
    done
  ) &
  SPINNER_PID=$!
  disown "$SPINNER_PID" 2>/dev/null
}

stop_spinner() {
  if [ -n "${SPINNER_PID:-}" ] && kill -0 "$SPINNER_PID" 2>/dev/null; then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
  fi
  SPINNER_PID=""
  clear_line
}

step_ok() {
  stop_spinner
  printf "  ${CHECK}  %s\n" "$1"
}

step_fail() {
  stop_spinner
  printf "  ${CROSS}  %s\n" "$1"
  INSTALL_FAILED=true
  show_cursor
  printf "\n  ${RED}${BOLD}Installation failed.${RESET}\n"
  printf "  ${DIM}Check the log for details: %s${RESET}\n\n" "$INSTALL_LOG"
  exit 1
}

step_warn() {
  stop_spinner
  printf "  ${WARN_SYM}  %s\n" "$1"
}

section() {
  echo ""
  printf "  ${WHITE}${BOLD}%s${RESET}\n" "$1"
  printf "  ${DIM}%s${RESET}\n" "$(printf '%.0s─' $(seq 1 ${#1}))"
}

# Run a command silently, capturing output to log
run_silent() {
  local desc="$1"
  shift
  echo "=== [$desc] $(date) ===" >> "$INSTALL_LOG"
  echo "CMD: $*" >> "$INSTALL_LOG"
  if "$@" >> "$INSTALL_LOG" 2>&1; then
    return 0
  else
    local rc=$?
    echo "EXIT CODE: $rc" >> "$INSTALL_LOG"
    return $rc
  fi
}

# Prompt the user for sudo access
require_sudo() {
  local package="$1"
  local reason="$2"
  if sudo -n true 2>/dev/null; then
    return 0
  fi
  stop_spinner
  echo ""
  printf "  ${ARROW}  ${BOLD}%s${RESET} %s\n" "$package" "$reason"
  printf "     ${DIM}Enter your password to continue:${RESET}\n"
  echo ""
  if sudo -v 2>/dev/null; then
    echo ""
    return 0
  else
    step_fail "sudo authentication failed"
  fi
}

# ---------------------------------------------------------------------------
# Dependency helpers
# ---------------------------------------------------------------------------

# Check if a command exists
command_exists() { command -v "$1" >/dev/null 2>&1; }

# Check if installed PHP meets minimum version requirement
# Returns 0 if PHP >= MIN_PHP_VERSION, 1 otherwise
php_version_ok() {
  if ! command_exists php; then
    return 1
  fi
  local current
  current="$(php -r 'echo PHP_MAJOR_VERSION . "." . PHP_MINOR_VERSION;' 2>/dev/null)" || return 1
  # Compare versions: split on dot, compare major then minor
  local cur_major cur_minor min_major min_minor
  cur_major="${current%%.*}"
  cur_minor="${current#*.}"
  min_major="${MIN_PHP_VERSION%%.*}"
  min_minor="${MIN_PHP_VERSION#*.}"
  if [ "$cur_major" -gt "$min_major" ] 2>/dev/null; then
    return 0
  elif [ "$cur_major" -eq "$min_major" ] && [ "$cur_minor" -ge "$min_minor" ] 2>/dev/null; then
    return 0
  fi
  return 1
}

# Install a package via the appropriate package manager (Linux only)
install_pkg() {
  local pkg="$1"
  local display_name="${2:-$1}"

  start_spinner "Installing ${display_name}..."

  if command_exists yum; then
    run_silent "$display_name" sudo yum install -y "$pkg" \
      && step_ok "$display_name" \
      || step_fail "Failed to install ${display_name}"
  elif command_exists apt-get; then
    run_silent "$display_name" sudo apt-get install -y "$pkg" \
      && step_ok "$display_name" \
      || step_fail "Failed to install ${display_name}"
  else
    step_fail "No supported package manager found (yum or apt-get)"
  fi
}

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------
hide_cursor
echo ""
printf "  ${BOLD}Protocol Installer${RESET}\n"
if [ "$USE_NIGHTLY" = true ]; then
  printf "  ${DIM}channel: nightly (latest master)${RESET}\n"
else
  printf "  ${DIM}channel: stable (latest release)${RESET}\n"
fi

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------
OS="$(uname -s)"

if [ "$OS" = "Darwin" ]; then
  # ==========================================================================
  # macOS
  # ==========================================================================

  section "Prerequisites"

  # Homebrew
  if command_exists brew; then
    step_ok "Homebrew $(brew --version 2>/dev/null | head -n1 | awk '{print $2}')"
  else
    step_fail "Homebrew is required — install from https://brew.sh/"
  fi

  # Docker
  if command_exists docker; then
    step_ok "Docker $(docker --version 2>/dev/null | head -n1)"
  elif command_exists orbstack; then
    step_ok "OrbStack (Docker-compatible)"
  else
    start_spinner "Installing Docker Desktop..."
    if run_silent "Docker" brew install --cask docker; then
      step_ok "Docker Desktop installed — launch it manually"
    else
      step_warn "Docker Desktop — skipped (install manually if needed)"
    fi
  fi

  # Docker Compose
  if command_exists docker && docker compose version >/dev/null 2>&1; then
    step_ok "Docker Compose $(docker compose version 2>/dev/null | head -n1)"
  elif command_exists docker-compose; then
    step_ok "Docker Compose $(docker-compose --version 2>/dev/null | head -n1)"
  else
    step_warn "Docker Compose — not found (install if needed)"
  fi

  # PHP
  if php_version_ok; then
    step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')"
  else
    if command_exists php; then
      step_warn "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}') — too old, need >=${MIN_PHP_VERSION}"
    fi
    start_spinner "Installing PHP >=${MIN_PHP_VERSION}..."
    if run_silent "PHP" brew install php@8.4; then
      # Homebrew doesn't always link versioned PHP
      run_silent "PHP link" brew link --overwrite --force php@8.4 2>/dev/null
      if php_version_ok; then
        step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')"
      else
        step_fail "PHP installed but version check failed — restart your shell and try again"
      fi
    else
      step_fail "Failed to install PHP >=${MIN_PHP_VERSION}"
    fi
  fi

  # Git
  if command_exists git; then
    step_ok "Git $(git --version 2>/dev/null | awk '{print $3}')"
  else
    start_spinner "Installing Git..."
    if run_silent "Git" brew install git; then
      step_ok "Git $(git --version 2>/dev/null | awk '{print $3}')"
    else
      step_fail "Failed to install Git"
    fi
  fi

  # Composer
  if command_exists composer; then
    step_ok "Composer $(composer --version 2>/dev/null | awk '{print $NF}' | head -n1)"
  else
    start_spinner "Installing Composer..."
    if run_silent "Composer" brew install composer; then
      step_ok "Composer $(composer --version 2>/dev/null | awk '{print $NF}' | head -n1)"
    else
      step_fail "Failed to install Composer"
    fi
  fi

  # ========================================================================
  # Install Protocol (macOS)
  # ========================================================================
  section "Protocol"

  # Determine install source
  if [ -f "$(cd "$(dirname "$0")" 2>/dev/null && pwd)/../$BINARY_NAME" ] 2>/dev/null; then
    PROTOCOL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    step_ok "Using local checkout at ${PROTOCOL_DIR}"
  elif [ -d "$INSTALL_DIR" ] && [ -f "$INSTALL_DIR/$BINARY_NAME" ]; then
    PROTOCOL_DIR="$INSTALL_DIR"
    step_ok "Found existing install at ${PROTOCOL_DIR}"

    # Update to correct ref
    start_spinner "Updating Protocol..."
    cd "$PROTOCOL_DIR"
    if [ "$USE_NIGHTLY" = true ]; then
      run_silent "git pull" git pull origin master
    else
      run_silent "git fetch" git fetch --tags
      LATEST_TAG="$(git describe --tags --abbrev=0 2>/dev/null || echo "")"
      if [ -n "$LATEST_TAG" ]; then
        run_silent "checkout release" git checkout "$LATEST_TAG"
      fi
    fi
    step_ok "Updated Protocol"
  else
    start_spinner "Cloning Protocol..."
    if [ "$USE_NIGHTLY" = true ]; then
      run_silent "git clone" git clone "$REPO_URL" "$INSTALL_DIR" \
        && step_ok "Cloned Protocol (nightly)" \
        || step_fail "Failed to clone repository"
    else
      # Clone then checkout latest tag
      if run_silent "git clone" git clone "$REPO_URL" "$INSTALL_DIR"; then
        cd "$INSTALL_DIR"
        LATEST_TAG="$(git describe --tags --abbrev=0 2>/dev/null || echo "")"
        if [ -n "$LATEST_TAG" ]; then
          run_silent "checkout release" git checkout "$LATEST_TAG"
          step_ok "Cloned Protocol ${LATEST_TAG}"
        else
          step_warn "Cloned Protocol — no release tags found, using master"
        fi
      else
        step_fail "Failed to clone repository"
      fi
    fi
    PROTOCOL_DIR="$INSTALL_DIR"
  fi

  # Install dependencies (clean vendor to avoid stale/partial installs)
  start_spinner "Installing dependencies..."
  cd "$PROTOCOL_DIR"
  rm -rf vendor
  if run_silent "composer install" composer install --no-interaction --no-dev; then
    step_ok "Dependencies installed"
  else
    step_fail "Failed to install dependencies (composer install)"
  fi

  # Make binary executable
  chmod +x "$PROTOCOL_DIR/$BINARY_NAME"

  # Add to PATH
  EXPORT_LINE="export PATH=\"$PROTOCOL_DIR:\$PATH\""
  FOUND=0
  for file in "$HOME/.zprofile" "$HOME/.zshrc"; do
    if [ -f "$file" ] && grep -Fxq "$EXPORT_LINE" "$file" 2>/dev/null; then
      FOUND=1
    fi
  done
  if [[ ":$PATH:" == *":$PROTOCOL_DIR:"* ]] || [ $FOUND -eq 1 ]; then
    step_ok "PATH already configured"
  else
    for file in "$HOME/.zprofile" "$HOME/.zshrc"; do
      [ ! -f "$file" ] && touch "$file"
      if ! grep -Fxq "$EXPORT_LINE" "$file" 2>/dev/null; then
        echo "$EXPORT_LINE" >> "$file"
      fi
    done
    export PATH="$PROTOCOL_DIR:$PATH"
    step_ok "Added to PATH (.zprofile, .zshrc)"
  fi

else
  # ==========================================================================
  # Linux
  # ==========================================================================
  PLATFORM=$(awk -F= '/^NAME/{print $2}' /etc/os-release 2>/dev/null || echo "unknown")

  section "System Update"

  case "$PLATFORM" in
    *"Amazon Linux"*)
      start_spinner "Updating system packages..."
      run_silent "yum update" sudo yum update -y \
        && step_ok "System packages updated" \
        || step_fail "System update failed"

      section "Docker"

      if command_exists docker; then
        step_ok "Docker $(docker --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Docker..."
        run_silent "docker" bash -c "sudo amazon-linux-extras enable docker && sudo yum install -y docker" \
          && step_ok "Docker installed" \
          || step_fail "Failed to install Docker"
      fi

      start_spinner "Enabling Docker service..."
      run_silent "docker service" bash -c "sudo systemctl enable docker.service && sudo systemctl start docker.service"
      sudo groupadd docker 2>/dev/null || true
      sudo usermod -aG docker "$USER" 2>/dev/null || true
      step_ok "Docker service running"

      if command_exists docker-compose; then
        step_ok "Docker Compose $(docker-compose --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Docker Compose..."
        run_silent "docker-compose" bash -c "wget -q https://github.com/docker/compose/releases/latest/download/docker-compose-\$(uname -s)-\$(uname -m) -O /tmp/docker-compose && sudo mv /tmp/docker-compose /usr/local/bin/docker-compose && sudo chmod +x /usr/local/bin/docker-compose" \
          && step_ok "Docker Compose installed" \
          || step_fail "Failed to install Docker Compose"
      fi

      section "Dependencies"

      if php_version_ok; then
        step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')"
      else
        if command_exists php; then
          step_warn "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}') — too old, need >=${MIN_PHP_VERSION}"
        fi
        start_spinner "Installing PHP >=${MIN_PHP_VERSION}..."
        # Detect AL2 vs AL2023
        if command_exists amazon-linux-extras; then
          # Amazon Linux 2 — use Remi repo for modern PHP
          run_silent "PHP" bash -c "
            sudo yum remove -y php-common php-cli php-fpm 2>/dev/null || true
            sudo yum install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-7.noarch.rpm 2>/dev/null || true
            sudo yum install -y https://rpms.remirepo.net/enterprise/remi-release-7.rpm 2>/dev/null || true
            sudo yum-config-manager --enable remi-php84
            sudo yum install -y php84-php-cli php84-php-pdo php84-php-fpm php84-php-json php84-php-mysqlnd php84-php-mbstring php84-php-xml
            # Link remi php into PATH
            if [ -f /opt/remi/php84/root/usr/bin/php ]; then
              sudo ln -sf /opt/remi/php84/root/usr/bin/php /usr/local/bin/php
            fi
          " && php_version_ok \
            && step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')" \
            || step_fail "Failed to install PHP >=${MIN_PHP_VERSION}. Amazon Linux 2 may require Amazon Linux 2023 for native PHP ${MIN_PHP_VERSION} support."
        else
          # Amazon Linux 2023 — PHP 8.4 available from amazonlinux repo
          run_silent "PHP" bash -c "
            sudo yum remove -y php-common php-cli php-fpm 2>/dev/null || true
            sudo dnf install -y php8.4-cli php8.4-pdo php8.4-fpm php8.4-mysqlnd php8.4-mbstring php8.4-xml
          " && php_version_ok \
            && step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')" \
            || step_fail "Failed to install PHP >=${MIN_PHP_VERSION}"
        fi
      fi

      if command_exists git; then
        step_ok "Git $(git --version 2>/dev/null | awk '{print $3}')"
      else
        install_pkg git "Git"
      fi

      if command_exists composer; then
        step_ok "Composer $(composer --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Composer..."
        run_silent "Composer" bash -c "curl -sS https://getcomposer.org/installer | php && sudo mv composer.phar /usr/local/bin/composer && sudo ln -sf /usr/local/bin/composer /usr/bin/composer" \
          && step_ok "Composer $(composer --version 2>/dev/null | head -n1)" \
          || step_fail "Failed to install Composer"
      fi
      ;;

    *"Ubuntu"*)
      start_spinner "Updating system packages..."
      run_silent "apt update" sudo apt-get update -y \
        && step_ok "System packages updated" \
        || step_fail "System update failed"

      section "Docker"

      if command_exists docker; then
        step_ok "Docker $(docker --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Docker..."
        run_silent "docker" bash -c "
          sudo apt-get remove -y docker docker-engine docker.io containerd runc 2>/dev/null || true
          sudo apt-get install -y ca-certificates curl gnupg lsb-release
          rm -f /usr/share/keyrings/docker-archive-keyring.gpg
          curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
          echo \"deb [arch=\$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu \$(lsb_release -cs) stable\" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
          sudo apt-get update -y
          sudo apt-get install -y docker-ce docker-ce-cli containerd.io
        " && step_ok "Docker installed" \
          || step_fail "Failed to install Docker"
      fi

      start_spinner "Enabling Docker service..."
      run_silent "docker service" bash -c "
        sudo groupadd docker 2>/dev/null || true
        sudo usermod -aG docker $USER 2>/dev/null || true
        sudo systemctl enable docker.service
        sudo systemctl enable containerd.service
        sudo systemctl start docker.service
        sudo systemctl start containerd.service
      "
      step_ok "Docker service running"

      if command_exists docker-compose; then
        step_ok "Docker Compose $(docker-compose --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Docker Compose..."
        run_silent "docker-compose" bash -c "
          sudo curl -L \"https://github.com/docker/compose/releases/download/1.29.2/docker-compose-\$(uname -s)-\$(uname -m)\" -o /usr/local/bin/docker-compose
          sudo chmod +x /usr/local/bin/docker-compose
          sudo ln -sf /usr/local/bin/docker-compose /usr/bin/docker-compose
        " && step_ok "Docker Compose installed" \
          || step_fail "Failed to install Docker Compose"
      fi

      section "Dependencies"

      if command_exists git; then
        step_ok "Git $(git --version 2>/dev/null | awk '{print $3}')"
      else
        install_pkg git "Git"
      fi

      if php_version_ok; then
        step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')"
      else
        if command_exists php; then
          step_warn "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}') — too old, need >=${MIN_PHP_VERSION}"
        fi
        start_spinner "Installing PHP >=${MIN_PHP_VERSION}..."
        run_silent "PHP" bash -c "
          sudo apt-get remove -y php-common php-cli 2>/dev/null || true
          sudo apt-get install -y software-properties-common
          sudo add-apt-repository -y ppa:ondrej/php
          sudo apt-get update -y
          sudo apt-get install -y php8.4-cli php8.4-xml php8.4-mbstring php8.4-curl php8.4-mysql
        " && php_version_ok \
          && step_ok "PHP $(php -v 2>/dev/null | head -n1 | awk '{print $2}')" \
          || step_fail "Failed to install PHP >=${MIN_PHP_VERSION}"
      fi

      if command_exists composer; then
        step_ok "Composer $(composer --version 2>/dev/null | head -n1)"
      else
        start_spinner "Installing Composer..."
        run_silent "Composer" bash -c "curl -sS https://getcomposer.org/installer | php && sudo mv composer.phar /usr/local/bin/composer && sudo ln -sf /usr/local/bin/composer /usr/bin/composer" \
          && step_ok "Composer $(composer --version 2>/dev/null | head -n1)" \
          || step_fail "Failed to install Composer"
      fi
      ;;

    *)
      step_fail "Unsupported platform: ${PLATFORM}"
      ;;
  esac

  # ==========================================================================
  # Install Protocol (Linux)
  # ==========================================================================
  section "Protocol"

  if [ -d "$INSTALL_DIR" ] && [ -f "$INSTALL_DIR/$BINARY_NAME" ]; then
    step_ok "Found existing install at ${INSTALL_DIR}"

    start_spinner "Updating Protocol..."
    cd "$INSTALL_DIR"
    if [ "$USE_NIGHTLY" = true ]; then
      run_silent "git pull" git pull origin master
      step_ok "Updated Protocol (nightly)"
    else
      run_silent "git fetch" git fetch --tags
      LATEST_TAG="$(git describe --tags --abbrev=0 2>/dev/null || echo "")"
      if [ -n "$LATEST_TAG" ]; then
        run_silent "checkout release" git checkout "$LATEST_TAG"
        step_ok "Updated Protocol ${LATEST_TAG}"
      else
        step_ok "Updated Protocol (no release tags, using master)"
      fi
    fi
  else
    start_spinner "Cloning Protocol..."
    if [ "$USE_NIGHTLY" = true ]; then
      run_silent "git clone" git clone "$REPO_URL" "$INSTALL_DIR" \
        && step_ok "Cloned Protocol (nightly)" \
        || step_fail "Failed to clone repository"
    else
      if run_silent "git clone" git clone "$REPO_URL" "$INSTALL_DIR"; then
        cd "$INSTALL_DIR"
        LATEST_TAG="$(git describe --tags --abbrev=0 2>/dev/null || echo "")"
        if [ -n "$LATEST_TAG" ]; then
          run_silent "checkout release" git checkout "$LATEST_TAG"
          step_ok "Cloned Protocol ${LATEST_TAG}"
        else
          step_warn "Cloned Protocol — no release tags found, using master"
        fi
      else
        step_fail "Failed to clone repository"
      fi
    fi
  fi

  # Install dependencies (clean vendor to avoid stale/partial installs)
  start_spinner "Installing dependencies..."
  cd "$INSTALL_DIR"
  rm -rf vendor
  if run_silent "composer install" composer install --no-interaction --no-dev; then
    step_ok "Dependencies installed"
  else
    step_fail "Failed to install dependencies (composer install)"
  fi

  # Make executable and install globally
  sudo chmod +x "$INSTALL_DIR/$BINARY_NAME"

  start_spinner "Setting up global 'protocol' command..."
  SYMLINK_TARGET="/usr/local/bin/protocol"
  if [ -L "$SYMLINK_TARGET" ] || [ -e "$SYMLINK_TARGET" ]; then
    sudo rm -f "$SYMLINK_TARGET"
  fi
  if sudo ln -s "$INSTALL_DIR/$BINARY_NAME" "$SYMLINK_TARGET" 2>/dev/null; then
    step_ok "Protocol installed globally ($SYMLINK_TARGET)"
  else
    step_warn "Global install failed — run 'sudo ln -s $INSTALL_DIR/$BINARY_NAME $SYMLINK_TARGET' manually"
  fi
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
echo ""
if command_exists protocol; then
  printf "  ${GREEN}${BOLD}Protocol is ready!${RESET}\n"
  printf "  ${DIM}Run 'protocol' to get started.${RESET}\n"
else
  printf "  ${GREEN}${BOLD}Installation complete!${RESET}\n"
  SHELL_NAME="$(basename "${SHELL:-/bin/bash}")"
  SHELL_RC=".${SHELL_NAME}rc"
  printf "  ${DIM}Restart your shell or run 'source ~/${SHELL_RC}' to use 'protocol'.${RESET}\n"
fi
echo ""
show_cursor
