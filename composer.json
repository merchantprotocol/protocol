{
    "name": "jonathonbyrdziak/protocol",
    "description": "Release-based deployment and infrastructure management for Docker applications",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Gitcd\\": "src/",
            "Gitcd\\Plugins\\": "src/Plugins/"
        }
    },
    "authors": [
        {
            "name": "Jonathon Byrdziak",
            "email": "jonathonbyrd@gmail.com"
        }
    ],
    "require": {
        "symfony/console": "^5.4",
        "symfony/lock": "^5.4",
        "symfony/yaml": "^5.4",
        "knplabs/github-api": "^3.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "http-interop/http-factory-guzzle": "^1.0",
        "aws/aws-sdk-php": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
